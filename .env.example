TELEGRAM_BOT_TOKEN=coloque_o_token_aqui
TELEGRAM_CHAT_ID=coloque_o_chat_id_aqui

# 245 dias ~= 8 meses.
SWEEP_DAYS_AHEAD=245

# Intervalo automatico do monitoramento.
SWEEP_INTERVAL_HOURS=4

# Pausa entre rotas/fontes para reduzir bloqueios.
ROUTE_DELAY_SECONDS=1.5

# Evita alerta repetido do mesmo tipo por rota.
ALERT_SILENCE_HOURS=6

# Mantem apenas a fonte protegida ativa por padrao.
# Use 1 somente para testar fontes novas, uma de cada vez.
ALLOW_EXPERIMENTAL_SOURCES=0

# Navegador persistente do Kayak.
KAYAK_PROFILE_DIR=data/browser_profiles/kayak

# Navegador persistente do Kiwi.
KIWI_PROFILE_DIR=data/browser_profiles/kiwi

# Proxy opcional para navegador.
BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=
