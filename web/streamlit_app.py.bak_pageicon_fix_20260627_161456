storage.init_db()

def safe_df(sql: str):
    try:
        return storage.df(sql)
    except Exception:
        return pd.DataFrame()

def rerun():
    st.rerun()

def route_options(routes):
    return {f"{r.origin} -> {r.destination} | {r.trip_type} | {r.id}": r.id for r in routes}

